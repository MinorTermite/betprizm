@echo off
chcp 65001 >nul
title PRIZMBET - Обновление матчей (Marathon)

echo.
echo ====================================================================
echo PRIZMBET - Обновление линии Marathon...
echo ====================================================================
echo.

cd /d "%~dp0"
python marathon_parser_real.py

if %errorlevel% neq 0 (
    echo.
    echo [ОШИБКА] Парсер завершился с ошибкой. Пуш отменён.
    echo.
    pause >nul
    exit /b 1
)

echo.
echo ====================================================================
echo Линия обновлена! Пушим на GitHub...
echo ====================================================================
echo.

git add matches.json
git commit -m "update: matches %DATE% %TIME:~0,5%"
git push

if %errorlevel% equ 0 (
    echo.
    echo ====================================================================
    echo [OK] Готово! Сайт обновится через ~1 минуту.
    echo ====================================================================
) else (
    echo.
    echo [ОШИБКА] Git push не удался. Проверьте подключение к интернету.
)

echo.
echo Нажмите любую клавишу для выхода...
pause >nul
